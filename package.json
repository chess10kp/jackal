{
  "name": "jackal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pi-powered, terminal-native Jac coding agent",
  "license": "MIT",
  "files": [
    "pi/chains",
    "pi/skills",
    "pi/prompts",
    "pi/mcp.json",
    "pi/SYSTEM.md"
  ],
  "dependencies": {
    "@juicesharp/rpiv-ask-user-question": "^1.5.0",
    "@juicesharp/rpiv-btw": "^1.5.0",
    "@pi-unipi/notify": "^2.0.1",
    "pi-lsp-extension": "^1.2.1",
    "pi-mcp-adapter": "^2.6.0",
    "pi-mermaid": "^0.3.0",
    "pi-subagents": "^0.24.2"
  },
  "scripts": {
    "postinstall": "patch-package",
    "build:agent": "tsc -p tsconfig.json",
    "check": "npm run build:agent && node dist/index.js --check",
    "run:agent": "node dist/index.js run",
    "start:agent-shell": "npm run build:agent && jac tui templates/shell.cl.jac --install --run"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.75.4",
    "@earendil-works/pi-ai": "^0.75.4",
    "ink": "^7.0.3",
    "patch-package": "^8.0.1",
    "react": "^19.2.6",
    "typescript-language-server": "^5.2.0"
  }
}
